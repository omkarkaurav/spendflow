# Copy this file to .env.local and fill in real values.

# Neon Postgres connection string.
# Get this from your Neon project dashboard -> Connection Details -> "Pooled connection".
# It looks like: postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# A random secret used to sign auth session tokens.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=nDX43Ra7iQUp3xWE9smAtBvHJc01I+eBHVeiq2C17s4=

# The URL your app is deployed at (used by NextAuth for callbacks).
# For local development this is fine as-is.
NEXTAUTH_URL=http://localhost:3000
